          "kv-ml-training-prod-001",
          "appi-ml-training-prod-001",
          "crmltrainingprod001"
        ],
        "references": []
      },
      {
        "name": "cpu-cluster-001",
        "type": "Microsoft.MachineLearningServices/workspaces/computes",
        "location": "eastus",
        "sku": "Standard_DS3_v2",
        "properties": {
          "computeType": "AmlCompute",
          "properties": {
            "scaleSettings": {
              "maxNodeCount": 4,
              "minNodeCount": 0,
              "nodeIdleTimeBeforeScaleDown": "PT120S"
            },
            "vmPriority": "Dedicated"
          }
        },
        "reasoning": {
          "whyChosen": "Scalable compute target for running training jobs.",
          "alternativesConsidered": ["Compute Instance", "AKS"],
          "tradeoffs": "Clusters scale to zero to save costs when not in use."
        },
        "dependencies": ["mlw-ml-training-prod-001"],
        "references": []
      },
      {
        "name": "diag-mlw-audit",
        "type": "Microsoft.Insights/diagnosticSettings",
        "location": "eastus",
        "sku": "N/A",
        "properties": {
          "workspaceId": "${log-ml-training-prod-001.id}",
          "logs": [
            { "category": "Audit", "enabled": true },
            { "category": "AmlComputeClusterEvent", "enabled": true }
          ],
          "metrics": [
            { "category": "AllMetrics", "enabled": true }
          ]
        },
        "reasoning": {
          "whyChosen": "Explicitly requested to enable audit logging for all training jobs.",
          "alternativesConsidered": [],
          "tradeoffs": "Incurs data ingestion costs in Log Analytics."
        },
        "dependencies": ["mlw-ml-training-prod-001", "log-ml-training-prod-001"],
        "references": []
